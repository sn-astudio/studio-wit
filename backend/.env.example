# ──────────────────────────────────────
# Database
# ──────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./wit.db
# MySQL 예시: mysql+aiomysql://user:pass@host:3306/dbname

# ──────────────────────────────────────
# JWT
# ──────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production

# ──────────────────────────────────────
# Google OAuth (프론트엔드와 동일한 Client ID)
# ──────────────────────────────────────
GOOGLE_CLIENT_ID=

# ──────────────────────────────────────
# AI Provider API Keys
# ──────────────────────────────────────
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=

# ──────────────────────────────────────
# AWS S3 / CloudFront
# ──────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=ap-northeast-2
CLOUDFRONT_DOMAIN=

# ──────────────────────────────────────
# CORS (쉼표 구분 또는 JSON 배열)
# ──────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
